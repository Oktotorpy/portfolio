# Portfolio CMS Environment Configuration
# Copy this to /opt/portfolio/.env and fill in values

# Domain (used by Caddy for auto-HTTPS)
DOMAIN=yourdomain.com

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=changeme_run_generate_hash_script

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme

# Database path
DB_PATH=/opt/portfolio/data/portfolio.db

# Upload directory
UPLOAD_DIR=/opt/portfolio/uploads

# CORS origin (your domain)
CORS_ORIGIN=https://yourdomain.com

# Backend port (internal, Caddy proxies to this)
BACKEND_PORT=8000

# Frontend port (internal, Caddy proxies to this)
FRONTEND_PORT=3000

# Internal API URL (used by SvelteKit server-side rendering)
INTERNAL_API_URL=http://localhost:8000

# --- CineVote (vitz.pro/cinevote) ---
# TMDb API key (v3) for movie search/posters. Free for personal use: themoviedb.org.
TMDB_API_KEY=
# Set to 0 only for local http dev so the session cookie works without HTTPS.
CV_COOKIE_SECURE=1

# Caddy profile: "default" = Caddy owns public :443 (normal).
# "xray" = a front Xray (VLESS+REALITY) owns :443 and Caddy serves the site on
# 127.0.0.1:8443 as its fallback (uses deploy/Caddyfile.xray). Set to xray ONLY
# on a host where Xray is installed and fronting 443.
CADDY_PROFILE=default

# --- Election data poller -------------------------------------------------
# The 4-minute poller (backend/jobs/poll_election.py, run by the
# portfolio-election-poll.timer) stays DORMANT until ELECTION_API_URL is set.
#
# Upstream Armenia election results API (simple GET returning the JSON array).
ELECTION_API_URL=
# Route the request through an Armenia exit. Examples:
#   socks5h://127.0.0.1:1080            (local proxy / VPN client)
#   http://user:pass@host:port         (authenticated HTTP/HTTPS proxy)
# Leave empty for a direct connection.
ELECTION_API_PROXY=
# Request timeout in seconds.
ELECTION_API_TIMEOUT=30
# Optional extra request headers as a JSON object, e.g.
#   {"Authorization":"Bearer XXX"}
ELECTION_API_HEADERS=
