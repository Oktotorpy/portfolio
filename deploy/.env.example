# Portfolio CMS Environment Configuration
# Copy this to /opt/portfolio/.env and fill in values

# Domain (used by Caddy for auto-HTTPS)
DOMAIN=yourdomain.com

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=changeme_run_generate_hash_script

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme

# Database path
DB_PATH=/opt/portfolio/data/portfolio.db

# Upload directory
UPLOAD_DIR=/opt/portfolio/uploads

# CORS origin (your domain)
CORS_ORIGIN=https://yourdomain.com

# Backend port (internal, Caddy proxies to this)
BACKEND_PORT=8000

# Frontend port (internal, Caddy proxies to this)
FRONTEND_PORT=3000

# Internal API URL (used by SvelteKit server-side rendering)
INTERNAL_API_URL=http://localhost:8000
